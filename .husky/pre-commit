bun run check
bun run test

# Remind to update specs when changing key areas
CHANGED=$(git diff --cached --name-only)
SPEC_DIRS="packages/server/src/api/ packages/server/src/tasks/ packages/server/src/db/ packages/server/src/agent/ packages/server/src/config.ts packages/shared/src/types.ts"
SPEC_TOUCHED=$(echo "$CHANGED" | grep -c "^specs/" || true)

for dir in $SPEC_DIRS; do
  if echo "$CHANGED" | grep -q "^$dir"; then
    if [ "$SPEC_TOUCHED" -eq 0 ]; then
      echo ""
      echo "⚠ Changed files in $dir but no specs/ updated."
      echo "  If this changes architecture, DB schema, APIs, or agent providers,"
      echo "  update the corresponding file in specs/."
      echo ""
      break
    fi
  fi
done
