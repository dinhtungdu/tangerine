#!/usr/bin/env bun
import { resolve } from "path";

// npm global install runs from node_modules; dev checkout doesn't.
const root = resolve(import.meta.dir, "..");
const isNpmInstall = root.includes("node_modules");

if (isNpmInstall) {
  await import("../dist/cli.js");
} else {
  await import("../packages/server/src/cli/index.ts");
}
