#!/usr/bin/env bun
import { existsSync } from "fs";
import { resolve } from "path";

// Use bundled CLI when available (npm installs), fall back to source (local dev)
const bundled = resolve(import.meta.dir, "../dist/cli.js");
if (existsSync(bundled)) {
  await import(bundled);
} else {
  await import("../packages/server/src/cli/index.ts");
}
