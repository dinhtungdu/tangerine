#!/bin/bash
# Restart loop for self-updating Tangerine server.
# Run this instead of `bin/tangerine start` when developing Tangerine itself.
# This script manages restarts itself, so it runs the server in foreground mode
# instead of using the CLI daemon.
# After "Pull Latest" the server exits 75 (DAEMON_RESTART_EXIT_CODE), which
# causes this loop to restart it. Exit 0 is also treated as a clean restart.
# Also watches ~/tangerine/config.json (or $TANGERINE_CONFIG) for changes and
# restarts on modification.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${TANGERINE_CONFIG:-$HOME/tangerine/config.json}"

echo "[tangerine-watch] Starting..."

watch_config() {
  # Event-driven watching with fallback to polling for portability.
  if command -v inotifywait &>/dev/null; then
    inotifywait -q -e close_write,moved_to "$(dirname "$CONFIG_FILE")" \
      --include "$(basename "$CONFIG_FILE")" 2>/dev/null
  elif command -v fswatch &>/dev/null; then
    fswatch -1 "$CONFIG_FILE" >/dev/null 2>&1
  else
    # Polling fallback — check mtime every 2s
    local last_mod
    last_mod=$(stat -f %m "$CONFIG_FILE" 2>/dev/null || stat -c %Y "$CONFIG_FILE" 2>/dev/null || echo 0)
    while true; do
      sleep 2
      local cur_mod
      cur_mod=$(stat -f %m "$CONFIG_FILE" 2>/dev/null || stat -c %Y "$CONFIG_FILE" 2>/dev/null || echo 0)
      [ "$cur_mod" != "$last_mod" ] && break
    done
  fi
  echo "[tangerine-watch] Config changed, restarting server..."
  kill "$SERVER_PID" 2>/dev/null
}

while true; do
  # Resolve stable symlink so restarts pick up a refreshed SSH agent
  [ -S "$HOME/.ssh/agent.sock" ] && export SSH_AUTH_SOCK="$HOME/.ssh/agent.sock"

  bun "$SCRIPT_DIR/tangerine" start --foreground &
  SERVER_PID=$!

  watch_config &
  WATCHER_PID=$!

  wait "$SERVER_PID"
  EXIT_CODE=$?

  kill "$WATCHER_PID" 2>/dev/null
  wait "$WATCHER_PID" 2>/dev/null

  # Exit 0 = clean shutdown/update (legacy), exit 75 = explicit restart request
  if [ "$EXIT_CODE" -eq 0 ] || [ "$EXIT_CODE" -eq 75 ]; then
    echo "[tangerine-watch] Clean exit (code $EXIT_CODE), restarting in 2s..."
    sleep 2
  else
    echo "[tangerine-watch] Server exited with code $EXIT_CODE, stopping."
    exit "$EXIT_CODE"
  fi
done
