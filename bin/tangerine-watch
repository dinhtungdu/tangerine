#!/bin/bash
# Restart loop for self-updating Tangerine server.
# Run this instead of `bin/tangerine start` when developing Tangerine itself.
# The server polls git every 60s; on new commits it pulls and exits 0, which
# causes this loop to restart it automatically.
# Also watches ~/tangerine/config.json (or $TANGERINE_CONFIG) for changes and
# restarts on modification.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${TANGERINE_CONFIG:-$HOME/tangerine/config.json}"

echo "[tangerine-watch] Starting..."

watch_config() {
  local last_mtime
  last_mtime=$(stat -c %Y "$CONFIG_FILE" 2>/dev/null || echo "0")
  while true; do
    sleep 2
    local current_mtime
    current_mtime=$(stat -c %Y "$CONFIG_FILE" 2>/dev/null || echo "0")
    if [ "$current_mtime" != "$last_mtime" ]; then
      echo "[tangerine-watch] Config changed, restarting server..."
      kill "$SERVER_PID" 2>/dev/null
      return
    fi
  done
}

while true; do
  TANGERINE_SELF_UPDATE=1 bun "$SCRIPT_DIR/tangerine" start &
  SERVER_PID=$!

  watch_config &
  WATCHER_PID=$!

  wait "$SERVER_PID"
  EXIT_CODE=$?

  kill "$WATCHER_PID" 2>/dev/null
  wait "$WATCHER_PID" 2>/dev/null

  if [ "$EXIT_CODE" -eq 0 ]; then
    echo "[tangerine-watch] Clean exit (self-update), restarting in 2s..."
    sleep 2
  else
    echo "[tangerine-watch] Server exited with code $EXIT_CODE, stopping."
    exit "$EXIT_CODE"
  fi
done
